# Optional: an Ethereum JSON-RPC URL used by pnpm update-data to count daily
# on-chain blocks. The generator falls back to public RPCs when unset.
ETH_RPC_URL=

# Required in Vercel for Blob-backed reads and writes. Vercel creates this when
# a Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=

# Required in Vercel. Vercel Cron sends Authorization: Bearer $CRON_SECRET.
CRON_SECRET=

# Optional daily artifact Blob pathname override. Defaults to
# data/mev-watch.sqlite.
MEV_WATCH_BLOB_PATH=

# Optional Blob read cache TTL in milliseconds. Defaults to 300000.
MEV_WATCH_BLOB_CACHE_TTL_MS=

# Optional local SQLite artifact path. Defaults to src/data/mev-watch.sqlite.
MEV_WATCH_SQLITE_PATH=

# Optional live-ledger snapshot overrides. Local development defaults to
# data/live-ledger/. Blob-backed production defaults to data/live-ledger/.
MEV_WATCH_LIVE_SNAPSHOT_DIR=
MEV_WATCH_LIVE_BLOB_PREFIX=

# Optional update-data controls. Local pnpm update-data defaults to concurrency
# 8 and writes every 25 fetched days. The production cron route defaults to
# max-days 30, repair-max-days equal to max-days, concurrency 4, and write-every
# 1.
UPDATE_DATA_MAX_DAYS=
UPDATE_DATA_REPAIR_MAX_DAYS=
UPDATE_DATA_CONCURRENCY=
UPDATE_DATA_WRITE_EVERY=

# Optional backfill-and-upload paths. The backfill script copies the seed to the
# working file if the working file does not already exist, then uploads the
# working file to MEV_WATCH_BLOB_PATH.
MEV_WATCH_BACKFILL_SEED_PATH=
MEV_WATCH_BACKFILL_PATH=

# Optional Google Tag Manager container ID (e.g. GTM-XXXXXXX). When set, the
# layout loads the GTM container in both the <head> script and <body> noscript
# fallback. Configure GA4 (and any other tags) inside the GTM container — the
# app no longer fires gtag.js directly. Leave blank in dev to skip loading.
NEXT_PUBLIC_GTM_ID=

# Vercel Analytics and Speed Insights are wired via @vercel/analytics and
# @vercel/speed-insights and require no env vars; they auto-detect the Vercel
# environment and only send beacons from deployed previews and production.
