# Local development: a libSQL file. Production: a Turso libsql:// URL.
DATABASE_URL=file:./data/mevwatch.db

# Required only for a hosted Turso database (production). Leave empty locally.
DATABASE_AUTH_TOKEN=

# Shared secret protecting the /api/refresh cron endpoint (production).
CRON_SECRET=

# Optional: a Slack incoming-webhook URL for refresh-failure alerts.
SLACK_WEBHOOK_URL=

# Optional: an Ethereum JSON-RPC URL used to count daily on-chain blocks
# (the non-MEV-boost share). Falls back to public RPCs when unset.
ETH_RPC_URL=

# Selects the relay data source. 'relayscan' (default) uses relayscan's
# inflated per-payload aggregates; 'composite' uses Dune's per-slot winner.
DATA_SOURCE_MODE=relayscan

# Dune Analytics — required when DATA_SOURCE_MODE=composite.
# Sign in at dune.com and create a free API key under Settings → API.
DUNE_API_KEY=
# Numeric ID of the saved Dune query (see docs/dune/payloads-delivered.sql).
# Visible in the Dune URL: dune.com/queries/<this-id>.
DUNE_PAYLOADS_QUERY_ID=
