#/----------------settings/metadata-----------------/
DOTENV_VAULT="vlt_e755c8f98057d20e93815689f86f440b043e44012b956b71f89e00b6bc1c6494"
DOTENV_API_URL="https://vault.dotenv.org"
DOTENV_CLI="npx dotenv-vault@latest"
