{
  "name": "server",
  "version": "1.0.0",
  "description": "Express server for repo",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "ts-node-dev --require dotenv/config --require tsconfig-paths/register src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "NODE_ENV=production node --require dotenv/config ./dist/index.js",
    "populate-block-data": "ts-node --require tsconfig-paths/register ./src/scripts/populateBlockData.ts",
    "populate-relayers": "ts-node --require tsconfig-paths/register ./src/scripts/populateRelayers.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ethersproject/abstract-provider": "^5.7.0",
    "axios": "^0.27.2",
    "consts": "*",
    "database": "*",
    "ethers": "^5.7.1",
    "lodash": "^4.17.21",
    "mongodb": "^4.10.0",
    "node-html-parser": "^6.1.1",
    "typescript": "^4.6.3",
    "utils": "*"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.186",
    "ts-node-dev": "^1.1.8",
    "tsconfig": "*",
    "tsconfig-paths": "^3.14.1"
  }
}
