{
  "name": "turborepo-basic-shared",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "predocker:build:server": "npx turbo prune --scope=server --docker && cd out/full && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && cd ../..",
    "docker:build:server": "docker build -t block-indexer -f apps/blockIndexer/Dockerfile .",
    "predocker:build:server:ci": "yarn predocker:build:server",
    "docker:build:server:ci": "docker build -e DOTENV_ME=$DOTENV_ME --cache-from $LATEST_IMAGE_TAG -t $LATEST_IMAGE_TAG -t $IMAGE_TAG -f $DOCKERFILE ."
  },
  "devDependencies": {
    "@shopify/eslint-plugin": "^41.2.0",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.12",
    "eslint-config-labrys": "1.0.2",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.29.4",
    "eslint-plugin-react-hooks": "^4.3.0",
    "prettier": "^2.5.1",
    "turbo": "latest",
    "typescript": "^4.6.3"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=14.0.0"
  },
  "packageManager": "yarn@1.22.17"
}
