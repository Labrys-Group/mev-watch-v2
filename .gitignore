# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# editor
.vscode/

# testing
/coverage
/test-results
/playwright-report
/blob-report

# next.js / typescript build
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (commit .env.example only)
.env*
!.env.example

# vercel
.vercel

# scratch / tool caches
.superpowers
.understand-anything/
.gstack/
tmp_*

# local data artifacts (seed SQLite, live-ledger snapshots, e2e DBs)
/data/*
!/data/.gitkeep
/src/data/mev-watch.sqlite

# local design history (not committed)
docs/superpowers/
